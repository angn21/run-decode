# Strava API — https://www.strava.com/settings/api
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# App URL (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: seed tokens from Strava settings for quick local dev
# OAuth flow is preferred for production
STRAVA_ACCESS_TOKEN=
STRAVA_REFRESH_TOKEN=
# Unix timestamp (seconds) — optional; defaults to 6h from now if omitted
STRAVA_EXPIRES_AT=

# Session secret (any random string)
SESSION_SECRET=change-me-to-something-random

# Your IANA timezone — keeps week stats consistent local vs Vercel
# Examples: America/Toronto, America/New_York, Asia/Kolkata, Europe/London
RUN_DECODE_TIMEZONE=America/Toronto
